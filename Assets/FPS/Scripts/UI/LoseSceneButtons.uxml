<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement style="flex-grow: 1; top: auto;">
        <ui:VisualElement name="MenuContainer" style="flex-grow: 1; display: flex; justify-content: center; top: 25%;">
            <ui:Button text="Main Menu" name="BtnMainMenu" enable-rich-text="true" selectable="false" focusable="false" style="align-self: center; width: 15%; -unity-font-style: bold; background-color: rgb(191, 150, 83); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; border-left-color: rgb(103, 82, 50); border-right-color: rgb(103, 82, 50); border-top-color: rgb(103, 82, 50); border-bottom-color: rgb(103, 82, 50); font-size: 25px;"/>
            <ui:Button text="Play Again" name="BtnPlayAgain" style="justify-content: flex-start; align-self: center; width: 15%; -unity-font-style: bold; background-color: rgb(191, 150, 83); border-top-width: 2px; border-right-width: 2px; border-bottom-width: 2px; border-left-width: 2px; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; border-left-color: rgb(103, 82, 50); border-right-color: rgb(103, 82, 50); border-top-color: rgb(103, 82, 50); border-bottom-color: rgb(103, 82, 50); font-size: 25px;"/>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
